{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": "auth != null && data.child('players').child(auth.uid).exists()",
        ".write": "auth != null && data.child('meta').child('hostUid').val() === auth.uid",
        "meta": {
          ".read": "auth != null",
          ".write": "auth != null && (!data.exists() || data.child('hostUid').val() === auth.uid || newData.child('hostUid').val() === auth.uid)",
          ".validate": "newData.hasChildren(['hostUid', 'adult', 'alcohol', 'status']) && newData.child('hostUid').isString() && newData.child('adult').isBoolean() && newData.child('alcohol').isBoolean() && (newData.child('status').val() === 'lobby' || newData.child('status').val() === 'playing')"
        },
        "players": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "!newData.exists() || (newData.hasChildren(['name', 'avatarId', 'online']) && newData.child('name').isString() && newData.child('name').val().length > 0 && newData.child('name').val().length <= 20 && newData.child('avatarId').isString() && newData.child('avatarId').val().length > 0 && newData.child('avatarId').val().length <= 32 && newData.child('online').isBoolean())"
          }
        },
        "game": {
          ".read": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists()",
          ".write": "auth != null && root.child('rooms').child($roomCode).child('meta').child('hostUid').val() === auth.uid",
          "votes": {
            "$uid": {
              ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists() && (auth.uid === $uid || root.child('rooms').child($roomCode).child('meta').child('hostUid').val() === auth.uid)"
            }
          },
          "answers": {
            "$uid": {
              ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists() && (auth.uid === $uid || root.child('rooms').child($roomCode).child('meta').child('hostUid').val() === auth.uid)"
            }
          },
          "actions": {
            "$uid": {
              ".write": "auth != null && root.child('rooms').child($roomCode).child('players').child(auth.uid).exists() && (auth.uid === $uid || root.child('rooms').child($roomCode).child('meta').child('hostUid').val() === auth.uid)"
            }
          }
        }
      }
    }
  }
}
